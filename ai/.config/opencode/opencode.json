{
  "$schema": "https://opencode.ai/config.json",
  "provider": {},
  "mcp": {
      "jira": {
          "type": "remote",
          "url": "https://mcp.atlassian.com/v1/mcp"
      },
      "github": {
          "type": "remote",
          "url": "https://api.githubcopilot.com/mcp/",
