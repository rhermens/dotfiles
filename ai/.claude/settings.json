{
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"AGENTS.md\"; [ -f \"$f\" ] && jq -n --rawfile content \"$f\" '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":(\"Contents of AGENTS.md:\\n\\n\" + $content)}}' 2>/dev/null || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/roy/Projects/Claude-Code-Agent-Monitor/scripts/hook-handler.js\" SessionStart"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/roy/Projects/Claude-Code-Agent-Monitor/scripts/hook-handler.js\" PreToolUse"
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/roy/Projects/Claude-Code-Agent-Monitor/scripts/hook-handler.js\" PostToolUse"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/roy/Projects/Claude-Code-Agent-Monitor/scripts/hook-handler.js\" Stop"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/tmux/session-notify.sh"
          }
        ],
        "matcher": "*"
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/roy/Projects/Claude-Code-Agent-Monitor/scripts/hook-handler.js\" SubagentStop"
          }
        ],
        "matcher": "*"
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/roy/Projects/Claude-Code-Agent-Monitor/scripts/hook-handler.js\" Notification"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/roy/Projects/Claude-Code-Agent-Monitor/scripts/hook-handler.js\" SessionEnd"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/roy/Projects/Claude-Code-Agent-Monitor/scripts/hook-handler.js\" UserPromptSubmit"
          }
        ]
      }
    ]
  },
  "theme": "auto",
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true
}
