{
    "margin": "0",
    "spacing": "0",
    "clock": {
        "format": "[ {:%F %H:%M} ]"
    },
    "cpu": {
        "format": "Cpu: {usage}%"
    },
    "hyprland/workspaces": {
        "all-outputs": true
    },
    "memory": {
        "format": "Mem: {percentage}%"
    },
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-right": [
        "pulseaudio",
        "clock",
        "tray"
    ],
    "pulseaudio": {
        "format": "vol: {volume}%",
        "on-click": "hyprpwcenter"
    }
}
